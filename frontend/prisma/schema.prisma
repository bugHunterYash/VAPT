generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  password         String
  roleId           String
  role             Role              @relation(fields: [roleId], references: [id])
  organizationId   String?
  isActive         Boolean           @default(true)
  lastLogin        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  activities       UserActivity[]
  notifications    Notification[]

  createdProjects  Project[]         @relation("ProjectCreator")
  auditedProjects  Project[]         @relation("ProjectAuditor")
  reviewedProjects Project[]         @relation("ProjectReviewer")
  projectActivities ProjectActivity[]
  findings         Finding[]         @relation("FindingReporter")
  reviewComments   ReviewComment[]
  generatedReports ReportHistory[]
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  ipAddress String?
  device    String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id                String            @id @default(cuid())
  name              String
  poNumber          String?
  organization      String
  applicationName   String
  assessmentType    String
  priority          String
  environment       String
  targetUrl         String
  targetIp          String?
  status            String            @default("Assigned")
  expectedStartDate DateTime
  expectedEndDate   DateTime
  
  auditorId         String
  auditor           User              @relation("ProjectAuditor", fields: [auditorId], references: [id])
  
  reviewerId        String
  reviewer          User              @relation("ProjectReviewer", fields: [reviewerId], references: [id])
  
  createdBy         String
  creator           User              @relation("ProjectCreator", fields: [createdBy], references: [id])
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  activities        ProjectActivity[]
  findings          Finding[]
  checklists        ProjectChecklist[]
  reviewComments    ReviewComment[]
  assessmentSnapshots AssessmentSnapshot[]
  reportHistories   ReportHistory[]
}

model ProjectActivity {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  createdAt DateTime @default(now())
}

model Finding {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportedById     String
  reportedBy       User     @relation("FindingReporter", fields: [reportedById], references: [id])
  
  title            String
  severity         String   // Critical, High, Medium, Low, Informative
  status           String   @default("Open") // Open, Closed, Risk Accepted
  
  checklistId      String?  // The specific ProjectChecklist row this is tied to
  description      String?
  cvss             String?
  cwe              String?
  owasp            String?
  affectedUrls     String?
  poc              String?
  recommendation   String?
  evidenceUrls     String?  // JSON string or comma separated

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ReviewComment {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User     @relation(fields: [reviewerId], references: [id])
  
  category    String   // General, Checklist Item, Finding
  content     String
  attachment  String?
  
  createdAt   DateTime @default(now())
}

model AssessmentSnapshot {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  submissionNumber Int
  status           String   // Pending Review, Approved, Rejected
  
  checklistData    String   // JSON string of checklist items
  findingsData     String   // JSON string of findings
  reviewerComments String?  // JSON string or text of reviewer comments
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ReportHistory {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  generatedById String
  generatedBy   User     @relation(fields: [generatedById], references: [id])
  
  format        String   // PDF, DOCX, EXCEL
  filePath      String
  version       Int
  
  createdAt     DateTime @default(now())
}

// ----------------------------------------------------
// Assessment Workflow Checklist Tables
// ----------------------------------------------------

model ChecklistTemplate {
  id             String   @id @default(cuid())
  name           String
  assessmentType String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categories     ChecklistCategory[]
}

model ChecklistCategory {
  id          String   @id @default(cuid())
  templateId  String
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  name        String
  order       Int
  
  items       ChecklistItem[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  categoryId  String
  category    ChecklistCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  code        String
  title       String
  description String?
  tools       String?
  order       Int
}

model ProjectChecklist {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Snapshotted details so the project instance remains static even if templates change
  categoryName String
  code         String
  title        String
  description  String?
  tools        String?
  order        Int
  
  result       String   @default("Not Started") // Not Started, Pass, Issues, N/A
  remark       String?
  findingId    String?  // Can point to a Finding ID if result == 'Issues'
  
  updatedAt    DateTime @updatedAt
}
